# Public — sent to the browser (NEXT_PUBLIC_* only)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Grocery: experimental USB scale via Web Serial (Chrome/Edge, HTTPS or localhost)
# NEXT_PUBLIC_EXPERIMENTAL_WEB_SERIAL_SCALE=1

# Server-only (Server Components / route handlers)
API_SERVER_BASE_URL=http://localhost:8000

# Analytics (optional — tracker is a no-op when unset)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

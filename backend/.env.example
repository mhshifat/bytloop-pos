# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-prod

# ──────────────────────────────────────────────
# Database (local Postgres via pgAdmin)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bytloop_pos
DATABASE_POOL_SIZE=8
DATABASE_MAX_OVERFLOW=4
DATABASE_POOL_RECYCLE_SECONDS=300
DATABASE_POOL_TIMEOUT_SECONDS=5
DATABASE_POOL_PRE_PING=true

# Test DB (used by pytest fixtures)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bytloop_pos_test

# ──────────────────────────────────────────────
# Redis (local Memurai)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_MAX_APP_CONNECTIONS=15
REDIS_MAX_CELERY_BROKER_CONNECTIONS=8
REDIS_MAX_CELERY_RESULT_CONNECTIONS=4
REDIS_SOCKET_TIMEOUT_SECONDS=2.0
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=1.0
REDIS_OP_TIMEOUT_SECONDS=1.0
REDIS_CIRCUIT_BREAKER_THRESHOLD=5
REDIS_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30

# ──────────────────────────────────────────────
# Auth / JWT
# ──────────────────────────────────────────────
AUTH_JWT_SECRET=change-me-generate-with-openssl-rand
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_SECONDS=86400
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_ACTIVATION_TOKEN_TTL_SECONDS=86400
AUTH_PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
AUTH_RESEND_COOLDOWN_SECONDS=300
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_ARGON2_TIME_COST=3
AUTH_ARGON2_MEMORY_COST_KIB=65536

# OAuth
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
AUTH_OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Currency
# ──────────────────────────────────────────────
CURRENCY_SUPPORTED=BDT,USD
CURRENCY_DEFAULT=BDT
CURRENCY_EXCHANGE_RATE_PROVIDER=exchangerate_host

# ──────────────────────────────────────────────
# Payments
# ──────────────────────────────────────────────
PAYMENTS_BD_PROVIDERS=bkash,nagad,sslcommerz,rocket
PAYMENTS_GLOBAL_PROVIDERS=stripe,paypal

# ──────────────────────────────────────────────
# Email (SMTP/MailHog for dev)
# ──────────────────────────────────────────────
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=no-reply@bytloop-pos.local
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=false

# Mailgun (prod)
EMAIL_MAILGUN_API_KEY=
EMAIL_MAILGUN_DOMAIN=

# Route email through Celery (off the request path). Set to "true" in prod.
EMAIL_ASYNC_SEND=false

# ──────────────────────────────────────────────
# CORS / Frontend
# ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_RENDERER=pretty   # pretty | json
SENTRY_DSN=
POSTHOG_KEY=

# ──────────────────────────────────────────────
# Cannabis — purchase limits + compliance outbox (Celery: compliance_outbox_sync)
# ──────────────────────────────────────────────
CANNABIS_DAILY_GRAM_LIMIT=28
CANNABIS_METRC_API_BASE=
CANNABIS_BIOTRACK_API_BASE=
CANNABIS_BIOTRACK_TENANT_ID=
CANNABIS_PURCHASE_HISTORY_RETENTION_DAYS=90
# off | log (emit structlog only) | noop_success (mark rows SYNCED — dev/QA only)
CANNABIS_COMPLIANCE_OUTBOUND_MODE=off
CANNABIS_COMPLIANCE_OUTBOUND_BATCH_SIZE=50
# metrc | biotrack — used in log payload until real HTTP connectors exist
CANNABIS_COMPLIANCE_OUTBOUND_TARGET=metrc

# ──────────────────────────────────────────────
# AI / LLM provider (Groq for NL-SQL + insight captions)
# ──────────────────────────────────────────────
# "disabled" means analytics still work, but cohort captions and the
# /ai/reports/ask endpoint return degraded answers. Set to "groq" + supply
# the API key to enable.
AI_PROVIDER=disabled
AI_GROQ_API_KEY=
AI_GROQ_MODEL=llama-3.1-8b-instant
AI_REQUEST_TIMEOUT_SECONDS=15
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=800
